<Window
    x:Class="TransCoda.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:TransCoda.Models"
    Title="TransCoda">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom title bar so Mica flows behind it. -->
        <Grid x:Name="TitleBarArea" Grid.Row="0" Padding="16,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                <FontIcon Glyph="&#xE714;" FontSize="14" />
                <TextBlock
                    Text="TransCoda"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <!-- Queue -->
            <Grid
                Grid.Column="0"
                Padding="16,0,16,16"
                RowSpacing="12"
                Background="Transparent"
                AllowDrop="True"
                DragOver="Queue_DragOver"
                Drop="Queue_Drop">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                    <Button x:Name="AddButton" Click="Add_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE710;" FontSize="14" />
                            <TextBlock Text="Add files" />
                        </StackPanel>
                    </Button>
                    <Button
                        x:Name="StartButton"
                        Style="{StaticResource AccentButtonStyle}"
                        IsEnabled="False"
                        Click="Start_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE768;" FontSize="14" />
                            <TextBlock Text="Convert" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="ClearButton" IsEnabled="False" Click="Clear_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE74D;" FontSize="14" />
                            <TextBlock Text="Clear finished" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <InfoBar
                    x:Name="FfmpegInfoBar"
                    Grid.Row="1"
                    Severity="Warning"
                    IsOpen="False"
                    IsClosable="False"
                    Title="FFmpeg not found"
                    Message="Install FFmpeg (winget install Gyan.FFmpeg) or place ffmpeg.exe next to TransCoda.exe, then restart the app." />

                <ListView
                    x:Name="JobList"
                    Grid.Row="2"
                    ItemsSource="{x:Bind Queue.Jobs}"
                    SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:ConversionJob">
                            <Grid Padding="4,10" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <FontIcon
                                    Grid.Column="0"
                                    Glyph="&#xE714;"
                                    VerticalAlignment="Top"
                                    Margin="0,2,0,0"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="{x:Bind FileName}" TextTrimming="CharacterEllipsis" />
                                    <ProgressBar
                                        Value="{x:Bind Progress, Mode=OneWay}"
                                        Maximum="1"
                                        Visibility="{x:Bind IsRunning, Mode=OneWay}" />
                                    <TextBlock
                                        Text="{x:Bind StatusText, Mode=OneWay}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        TextWrapping="Wrap" />
                                </StackPanel>

                                <StackPanel
                                    Grid.Column="2"
                                    Orientation="Horizontal"
                                    Spacing="4"
                                    VerticalAlignment="Center">
                                    <Button
                                        Click="CancelJob_Click"
                                        Visibility="{x:Bind ShowCancel, Mode=OneWay}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="8,6"
                                        ToolTipService.ToolTip="Cancel">
                                        <FontIcon Glyph="&#xE711;" FontSize="12" />
                                    </Button>
                                    <Button
                                        Click="RevealJob_Click"
                                        Visibility="{x:Bind ShowReveal, Mode=OneWay}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="8,6"
                                        ToolTipService.ToolTip="Show in File Explorer">
                                        <FontIcon Glyph="&#xE838;" FontSize="12" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <StackPanel
                    x:Name="EmptyState"
                    Grid.Row="2"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="10">
                    <FontIcon
                        Glyph="&#xE896;"
                        FontSize="36"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock
                        Text="Drop media files here"
                        Style="{StaticResource SubtitleTextBlockStyle}"
                        HorizontalAlignment="Center" />
                    <TextBlock
                        Text="Video and audio files will be added to the conversion queue."
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>

            <!-- Output settings -->
            <ScrollViewer Grid.Column="1" Padding="0,0,16,16">
                <StackPanel Spacing="10">
                    <TextBlock Text="Output" Style="{StaticResource BodyStrongTextBlockStyle}" />

                    <ComboBox
                        x:Name="FormatBox"
                        Header="Format"
                        HorizontalAlignment="Stretch"
                        SelectionChanged="Format_Changed" />

                    <StackPanel x:Name="VideoSection" Spacing="10">
                        <ComboBox
                            x:Name="VideoCodecBox"
                            Header="Video codec"
                            HorizontalAlignment="Stretch"
                            SelectionChanged="VideoCodec_Changed" />
                        <Slider
                            x:Name="QualitySlider"
                            Header="Quality (CRF 23)"
                            Minimum="14"
                            Maximum="38"
                            StepFrequency="1"
                            Value="23"
                            ValueChanged="Quality_Changed" />
                        <ComboBox
                            x:Name="ResolutionBox"
                            Header="Resolution"
                            HorizontalAlignment="Stretch"
                            SelectionChanged="Resolution_Changed" />
                        <ToggleSwitch
                            x:Name="HardwareToggle"
                            Header="Hardware acceleration"
                            IsOn="True"
                            Toggled="Hardware_Toggled" />
                    </StackPanel>

                    <ComboBox
                        x:Name="AudioCodecBox"
                        Header="Audio codec"
                        HorizontalAlignment="Stretch"
                        SelectionChanged="AudioCodec_Changed" />
                    <ComboBox
                        x:Name="AudioBitrateBox"
                        Header="Audio bitrate"
                        HorizontalAlignment="Stretch"
                        SelectionChanged="AudioBitrate_Changed" />

                    <TextBlock
                        Text="Destination"
                        Style="{StaticResource BodyStrongTextBlockStyle}"
                        Margin="0,12,0,0" />
                    <TextBlock
                        x:Name="DestinationLabel"
                        Text="Same folder as source"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextTrimming="CharacterEllipsis" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Choose folder…" Click="ChooseFolder_Click" />
                        <Button
                            x:Name="ResetFolderButton"
                            Content="Reset"
                            Visibility="Collapsed"
                            Click="ResetFolder_Click" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
